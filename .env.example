# --- Supabase ---
# Project URL + service-role key (server-side workers only; never ship to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Anon key for the Next.js dashboard (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Intelligence (Groq — free tier) ---
# Free API key at https://console.groq.com  (no cost; rate-limited)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=

# --- Distribution (X / Twitter) ---
# Free tier: ~500 writes/month. Leave blank to run distribution in dry-run (log only).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- Tuning ---
# Impact score (0-100) at/above which we auto-post; below this is discarded (no human review).
# 60 = only "solidly newsworthy"+ (drops the 45-59 "worth a mention" tier to cut volume).
# Raise further (~70) for only big news.
AUTO_POST_THRESHOLD=60
# Max auto-posts per rolling 24h (X free-tier guardrail ≈ 16/day). Raise on a paid X plan.
DAILY_TWEET_BUDGET=200
# Pace the free LLM tier: how many filings to extract / analyze per 15s tick.
# Keep INTEL small (1-2) so we never burst past the per-minute rate limit.
EXTRACT_BATCH=2
INTEL_BATCH=1
# Hard ceiling on LLM calls per rolling 24h — comfortably under Groq free-tier's
# daily request cap. Once hit, analysis pauses until the window rolls off instead
# of grinding a large backlog into hard rate-limit errors.
LLM_DAILY_CALL_BUDGET=900

# --- AutoTweet (worker/autotweet.ts) — picks 1 best tweet every 7 min from Ticker's feed ---
# How often it runs. Default 7 minutes.
AUTOTWEET_POLL_MS=420000
# Active window shared with Ticker — both pause outside it (see lib/activeHours.ts).
# 8 = 8AM, 24 = through midnight. Hardcoded timezone: Asia/Kolkata.
ACTIVE_START_HOUR=8
ACTIVE_END_HOUR=24
# Sanity-floor score (0-100) to post — scoring is RELATIVE to the rest of each
# batch, not an absolute bar, so this just catches a degenerate response.
AUTO_TWEET_MIN_SCORE=20
# How far back (minutes) to look at auto_tweets for duplicate-topic context.
AUTO_TWEET_DEDUP_LOOKBACK_MIN=240
# Word-overlap (Jaccard) threshold for the backstop duplicate check, 0-1.
AUTO_TWEET_DEDUP_JACCARD=0.5
# Cap on articles sent to the LLM in one call — keeps a single request small and
# under Groq free-tier's tokens-per-minute limit even after a long backlog
# (e.g. worker was down a while). Normal 7-min cadence rarely gets close to this.
AUTO_TWEET_MAX_BATCH=60
# Rolling 24h LLM call ceiling for this engine (separate budget from the filings pipeline).
AUTOTWEET_LLM_DAILY_BUDGET=250
# How many auto_tweets rows to keep (rolling window, like RETAIN elsewhere).
AUTOTWEET_RETAIN=500
